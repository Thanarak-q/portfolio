---
import Base from "../layouts/Base.astro";
import ScrollInit from "../components/ScrollInit";
import HeroClip from "../components/HeroClip";
import SlideUpClip from "../components/SlideUpClip";
import { RiseIn, SlideIn, ScaleIn, LineReveal } from "../components/Reveal";
import ImageReveal from "../components/ImageReveal";
import PyramidFlip from "../components/PyramidFlip";
import RoleSlide from "../components/RoleSlide";
import BookShelf from "../components/BookShelf";
import {
  aboutLines,
  aboutStats,
  booksRead,
  contactLines,
  contactLinks,
  focusItems,
  navLinks,
  workItems,
  workLines,
} from "../lib/portfolioContent";
---

<Base>
  <ScrollInit client:load />

  <nav class="nav glass-liquid" aria-label="Primary">
    <div class="brand">
      <span class="dot" aria-hidden="true"></span>
      <span class="brand-name">thanarak</span>
      <span class="role-mini">/ cybersecurity</span>
    </div>
    <div class="nav-links">
      {navLinks.map((link) => (
        <a href={link.href} data-nav-link={link.label}>{link.label}</a>
      ))}
    </div>
    <a class="nav-cta" href="#contact" data-nav-link="Contact">Contact</a>
  </nav>

  <!-- HERO -->
  <div>
  <HeroClip
    client:load
    src="/assets/clip-1-scrub.mp4"
    title="Thanarak"
    titleItalic="Kanyaprasit"
    role="Cybersecurity / Penetration Testing / Product Security"
    runwayVH={500}
    showHint={true}
    portalEyebrow="CHAPTER 02"
    portalLabel="portfolio"
  />
  </div>

  <!-- ABOUT -->
  <PyramidFlip client:load />
  <RoleSlide client:load />

  <!-- INTERLUDE 1 -->
  <div id="interlude-1">
  <SlideUpClip
    client:load
    src="/assets/clip-2-scrub.mp4"
    eyebrow="Interlude — 00:06 / 00:18"
    title="Start with"
    titleItalic="the basics."
    caption="Good security work starts with careful observation, clear notes, and understanding how the system actually behaves."
    runwayVH={400}
    exitDirection="left"
  />
  </div>

  <section id="focus" class="focus-loop">
    <div class="focus-loop-intro wrap" data-focus-intro>
      <div class="focus-loop-copy">
        <div class="eyebrow" data-focus-intro-item>02 — Focus</div>
        <h2 class="focus-loop-title">
          <span class="focus-loop-title-row">
            <span data-focus-intro-line>What I'm</span>
          </span>
          <span class="focus-loop-title-row focus-loop-title-row--accent">
            <em data-focus-intro-line>working on now.</em>
          </span>
        </h2>
        <p class="focus-loop-caption" data-focus-intro-item>
          Web application penetration testing, threat intelligence, and custom
          tooling — with AI security as an active learning interest.
        </p>
      </div>
    </div>

    {focusItems.map((item, i) => (
      <ImageReveal
        client:load
        index={i + 1}
        total={focusItems.length}
        name={item.name}
        src={item.src}
        alt={item.alt}
      />
    ))}

    <BookShelf client:load books={booksRead} />
  </section>

  <!-- INTERLUDE 2 -->
  <div id="interlude-2">
  <SlideUpClip
    client:load
    src="/assets/clip-3-scrub.mp4"
    eyebrow="Interlude — 00:12 / 00:18"
    title="Learn, test,"
    titleItalic="improve."
    caption="Each lab, challenge, and write-up adds a little more clarity to how systems break and how they can be made safer."
    runwayVH={400}
  />
  </div>

  <!-- WORK -->
  <section id="work" class="content">
    <div class="wrap">
      <RiseIn client:load distance={40}>
        <div class="eyebrow">03 — Experience</div>
      </RiseIn>

      <LineReveal
        client:load
        class="big-statement"
        lines={workLines}
      />

      <div class="work-list glass-liquid">
        {workItems.map((item, index) => (
          <SlideIn
            client:load
            dir="right"
            distance={120}
            delay={0.04 + index * 0.05}
          >
            <div class:list={["row", { "row-sep": index > 0 }]}>
              <div class="num">{item.number}</div>
              <div class="title">
                {item.title}{" "}
                {item.titleItalic && <span class="it">{item.titleItalic}</span>}
              </div>
              <div class="desc">{item.description}</div>
              <div class="meta">{item.meta}</div>
            </div>
          </SlideIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="content contact-bg">
    <video
      class="contact-bg-video"
      data-contact-video
      src="/assets/ending.mp4"
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="contact-bg-scrim" aria-hidden="true"></div>

    <div class="wrap">
      <div class="eyebrow">04 — Contact</div>

      <h2 class="big-statement" set:html={contactLines.join(" ")} />

      <div class="glass-liquid contact-card">
        <p class="body contact-intro">
          Open to Product Security, Application Security, and Penetration Testing
          roles in Bangkok, Chiang Mai, or remote. Focused on securing applications
          across the development lifecycle — from secure design and development
          through testing and remediation.
        </p>
        <div class="contact-actions">
          {contactLinks.map((link) => (
            <a
              class="link-pill"
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              <span>{link.label}</span><span class="arrow">↗</span>
            </a>
          ))}
        </div>
      </div>

      <footer class="foot">
        © 2026 Thanarak Kanyaprasit · Product security portfolio
      </footer>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const contactVideo = document.querySelector<HTMLVideoElement>("[data-contact-video]");
    const contactSection = document.getElementById("contact");
    const navLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")
    );

    const sectionMap = [
      { id: "hero", label: "Intro" },
      { id: "about", label: "About" },
      { id: "role-slide", label: "About" },
      { id: "interlude-1", label: "Focus" },
      { id: "focus", label: "Focus" },
      { id: "interlude-2", label: "Focus" },
      { id: "work", label: "Work" },
      { id: "contact", label: "Contact" },
    ];

    const navSections = sectionMap
      .map((item) => {
        const element = document.getElementById(item.id);
        return element ? { ...item, element } : null;
      })
      .filter(Boolean);

    let activeLabel = "Intro";

    const renderActiveSection = (label: string) => {
      activeLabel = label;

      navLinks.forEach((link) => {
        const isActive = link.dataset.navLink === label;
        link.classList.toggle("is-active", isActive);
        if (isActive) {
          link.setAttribute("aria-current", "location");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    const updateActiveSection = () => {
      if (!navSections.length) return;

      const probe = window.scrollY + window.innerHeight * 0.36;
      let nextLabel = navSections[0].label;

      for (const item of navSections) {
        const top = item.element.offsetTop;
        const bottom = top + item.element.offsetHeight;

        if (probe >= top && probe < bottom) {
          nextLabel = item.label;
        }
      }

      if (nextLabel !== activeLabel) {
        renderActiveSection(nextLabel);
      }
    };

    renderActiveSection(activeLabel);
    updateActiveSection();
    window.addEventListener("scroll", updateActiveSection, { passive: true });
    window.addEventListener("resize", updateActiveSection);

    const focusIntro = document.querySelector<HTMLElement>("[data-focus-intro]");
    const focusIntroItems = gsap.utils.toArray<HTMLElement>("[data-focus-intro-item]");
    const focusIntroLines = gsap.utils.toArray<HTMLElement>("[data-focus-intro-line]");

    if (
      focusIntro &&
      focusIntroItems.length &&
      focusIntroLines.length &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      const focusIntroCopy = focusIntro.querySelector<HTMLElement>(".focus-loop-copy");

      const splitToChars = (el: HTMLElement) => {
        const text = el.textContent ?? "";
        el.textContent = "";
        const chars: HTMLSpanElement[] = [];
        for (const ch of text) {
          const span = document.createElement("span");
          span.className = "focus-char";
          if (ch === " ") {
            span.innerHTML = "&nbsp;";
          } else {
            span.textContent = ch;
          }
          el.appendChild(span);
          chars.push(span);
        }
        return chars;
      };

      const lineChars: HTMLSpanElement[][] = focusIntroLines.map(splitToChars);
      const allChars = lineChars.flat();

      gsap.set(focusIntroItems, { y: 24, opacity: 0, filter: "blur(8px)" });
      gsap.set(allChars, { yPercent: 120, opacity: 0, rotate: 6, transformOrigin: "0% 100%" });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: focusIntroCopy ?? focusIntro,
          start: "top 80%",
          toggleActions: "play reverse play reverse",
        },
      });

      tl.to(focusIntroItems, {
        y: 0,
        opacity: 1,
        filter: "blur(0px)",
        duration: 0.7,
        stagger: 0.12,
        ease: "power3.out",
      });

      lineChars.forEach((chars, lineIndex) => {
        tl.to(
          chars,
          {
            yPercent: 0,
            opacity: 1,
            rotate: 0,
            duration: 0.85,
            ease: "expo.out",
            stagger: {
              each: 0.022,
              from: lineIndex === 1 ? "random" : "start",
            },
          },
          lineIndex === 0 ? 0.05 : 0.32
        );
      });

      tl.to(
        focusIntro,
        {
          "--focus-rule-scale": 1,
          duration: 0.9,
          ease: "power3.out",
        },
        0.1
      );

      if (focusIntroCopy) {
        gsap.to(focusIntroCopy, {
          yPercent: -22,
          opacity: 0.12,
          scale: 0.9,
          ease: "none",
          scrollTrigger: {
            trigger: focusIntro,
            start: "center center",
            end: "bottom top",
            scrub: 0.9,
          },
        });
      }
    }

    if (contactVideo && contactSection) {
      const playContactVideo = () => {
        contactVideo.play().catch(() => {});
      };

      const pauseContactVideo = () => {
        contactVideo.pause();
      };

      new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            playContactVideo();
          } else {
            pauseContactVideo();
          }
        },
        {
          rootMargin: "65% 0px 65% 0px",
          threshold: 0,
        }
      ).observe(contactSection);
    }
  </script>
</Base>
