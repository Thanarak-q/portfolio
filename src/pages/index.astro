---
import Base from "../layouts/Base.astro";
import ScrollInit from "../components/ScrollInit";
import HeroClip from "../components/HeroClip";
import SlideUpClip from "../components/SlideUpClip";
import { RiseIn, SlideIn, ScaleIn, LineReveal } from "../components/Reveal";
import ImageReveal from "../components/ImageReveal";
import {
  aboutLines,
  aboutStats,
  booksRead,
  contactLines,
  contactLinks,
  focusItems,
  navLinks,
  workItems,
  workLines,
} from "../lib/portfolioContent";
---

<Base>
  <ScrollInit client:load />

  <nav class="nav glass-liquid" aria-label="Primary">
    <div class="brand">
      <span class="dot" aria-hidden="true"></span>
      <span class="brand-name">thanarak</span>
      <span class="role-mini">/ red&nbsp;team</span>
    </div>
    <div class="nav-links">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </div>
    <a class="nav-cta" href="#contact">Contact</a>
  </nav>

  <!-- HERO -->
  <div id="hero">
  <HeroClip
    client:load
    src="/assets/clip-1-scrub.mp4"
    title="Thanarak"
    titleItalic="Kanyaprasit"
    role="Red Team / Offensive Security / AI Security"
    runwayVH={500}
    showHint={true}
    portalEyebrow="CHAPTER 02"
    portalLabel="portfolio"
  />
  </div>

  <!-- ABOUT -->
  <section id="about" class="content">
    <div class="wrap">
      <RiseIn client:load distance={30}>
        <div class="eyebrow">01 — Who</div>
      </RiseIn>

      <LineReveal
        client:load
        class="big-statement"
        lines={aboutLines}
      />

      <div class="about-grid">
        <RiseIn client:load distance={60} delay={0.05}>
          <div class="glass-liquid about-card">
            <p class="lead about-lead">
              I help teams understand how their systems behave under pressure,
              from identity paths to LLM agents and the tooling around them.
            </p>
            <p class="body about-body">
              I'm Thanarak Kanyaprasit, an offensive security researcher focused on
              red-team operations, AI security, cloud escalation, and practical
              security research. This portfolio collects selected engagements,
              experiments, tools, and notes that show how I think through attack paths.
            </p>
          </div>
        </RiseIn>

        <div class="about-side">
          {aboutStats.map((stat, index) => (
            <RiseIn client:load distance={60} delay={0.1 + index * 0.08}>
              <div class="glass-liquid stat">
                <span class="k">{stat.value}</span>
                <span class="l">{stat.label}</span>
              </div>
            </RiseIn>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- INTERLUDE 1 -->
  <div id="interlude-1">
  <SlideUpClip
    client:load
    src="/assets/clip-2-scrub.mp4"
    eyebrow="Interlude — 00:06 / 00:18"
    title="Offense starts"
    titleItalic="with observation."
    caption="I map assumptions, access paths, and human workflows before touching the first exploit."
    runwayVH={400}
    exitDirection="left"
  />
  </div>

  <section id="focus" class="focus-loop">
    {focusItems.map((item, i) => (
      <ImageReveal
        client:load
        index={i + 1}
        total={focusItems.length}
        name={item.name}
        duration={item.duration}
        type={item.type}
        year={item.year}
        src={item.src}
        alt={item.alt}
      />
    ))}

    <section class="books-collage">
      <header class="bc-header">
        <h2 class="bc-meta-label">Reading log</h2>
        <span class="bc-meta-counter" data-counter>01 / {String(booksRead.length).padStart(2, "0")}</span>
        <span class="bc-meta-year">2025 — 2026</span>
      </header>

      <div class="bc-stage" aria-live="polite">
        <p class="bc-quote">
          <span class="bc-quote-mark" aria-hidden="true">&ldquo;</span><span class="bc-quote-text" data-quote>{booksRead[0].note}</span><span class="bc-quote-mark" aria-hidden="true">&rdquo;</span>
        </p>
        <p class="bc-attribution" data-attribution>— {booksRead[0].title}</p>
      </div>

      {booksRead.map((b, i) => (
        <button
          type="button"
          class:list={["books-card", `books-card-${i + 1}`, { "is-active": i === 0 }]}
          data-index={i}
          data-note={b.note}
          data-title={b.title}
        >
          <span class="bc-num">{String(i + 1).padStart(2, "0")}</span>
          <span class="bc-title">{b.title}</span>
        </button>
      ))}
    </section>
  </section>

  <script>
    const collage = document.querySelector<HTMLElement>(".books-collage");
    if (collage) {
      const cards = Array.from(collage.querySelectorAll<HTMLButtonElement>(".books-card"));
      const quoteEl = collage.querySelector<HTMLElement>("[data-quote]");
      const attrEl = collage.querySelector<HTMLElement>("[data-attribution]");
      const counterEl = collage.querySelector<HTMLElement>("[data-counter]");
      const stageEl = collage.querySelector<HTMLElement>(".bc-stage");
      const total = cards.length;
      const pad = (n: number) => String(n).padStart(2, "0");

      let active = 0;
      let timer = 0;
      let hovering = false;

      const setActive = (idx: number) => {
        if (idx === active) return;
        active = idx;
        const card = cards[idx];
        if (!card) return;
        const note = card.dataset.note ?? "";
        const title = card.dataset.title ?? "";

        cards.forEach((c, i) => c.classList.toggle("is-active", i === idx));

        if (quoteEl) quoteEl.style.opacity = "0";
        if (attrEl) attrEl.style.opacity = "0";

        window.setTimeout(() => {
          if (quoteEl) {
            quoteEl.textContent = note;
            quoteEl.style.opacity = "1";
          }
          if (attrEl) {
            attrEl.textContent = `— ${title}`;
            attrEl.style.opacity = "1";
          }
          if (counterEl) counterEl.textContent = `${pad(idx + 1)} / ${pad(total)}`;
        }, 220);
      };

      const startCycle = () => {
        window.clearInterval(timer);
        timer = window.setInterval(() => {
          if (hovering) return;
          setActive((active + 1) % total);
        }, 4500);
      };

      cards.forEach((card, i) => {
        const enter = () => {
          hovering = true;
          collage.setAttribute("data-hovering", "true");
          setActive(i);
        };
        const leave = () => {
          hovering = false;
          collage.removeAttribute("data-hovering");
        };
        card.addEventListener("mouseenter", enter);
        card.addEventListener("focus", enter);
        card.addEventListener("mouseleave", leave);
        card.addEventListener("blur", leave);
      });

      if (stageEl) {
        let raf = 0;
        document.addEventListener("mousemove", (e) => {
          cancelAnimationFrame(raf);
          raf = requestAnimationFrame(() => {
            const dx = (e.clientX / window.innerWidth - 0.5) * 14;
            const dy = (e.clientY / window.innerHeight - 0.5) * 9;
            stageEl.style.setProperty("--mx", `${dx}px`);
            stageEl.style.setProperty("--my", `${dy}px`);
          });
        }, { passive: true });
      }

      new IntersectionObserver(([e]) => {
        if (e.isIntersecting) {
          collage.classList.add("is-visible");
          startCycle();
        } else {
          window.clearInterval(timer);
        }
      }, { threshold: 0.15 }).observe(collage);
    }
  </script>

  <!-- INTERLUDE 2 -->
  <div id="interlude-2">
  <SlideUpClip
    client:load
    src="/assets/clip-3-scrub.mp4"
    eyebrow="Interlude — 00:12 / 00:18"
    title="Good findings"
    titleItalic="become better systems."
    caption="The point is not just impact. It is a clear path from evidence to remediation."
    runwayVH={400}
  />
  </div>

  <!-- WORK -->
  <section id="work" class="content">
    <div class="wrap">
      <RiseIn client:load distance={40}>
        <div class="eyebrow">03 — Selected work</div>
      </RiseIn>

      <LineReveal
        client:load
        class="big-statement"
        lines={workLines}
      />

      <div class="work-list glass-liquid">
        {workItems.map((item, index) => (
          <SlideIn
            client:load
            dir="right"
            distance={120}
            delay={0.04 + index * 0.05}
          >
            <div class:list={["row", { "row-sep": index > 0 }]}>
              <div class="num">{item.number}</div>
              <div class="title">
                {item.title}{" "}
                {item.titleItalic && <span class="it">{item.titleItalic}</span>}
              </div>
              <div class="desc">{item.description}</div>
              <div class="meta">{item.meta}</div>
            </div>
          </SlideIn>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="content contact-bg">
    <video
      class="contact-bg-video"
      data-contact-video
      src="/assets/ending.mp4"
      muted
      loop
      playsinline
      preload="metadata"
      aria-hidden="true"
    ></video>
    <div class="contact-bg-scrim" aria-hidden="true"></div>

    <div class="wrap">
      <div class="eyebrow">04 — Contact</div>

      <h2 class="big-statement" set:html={contactLines.join(" ")} />

      <div class="glass-liquid contact-card">
        <p class="body contact-intro">
          Available for red-team engagements, AI-security research, cloud and
          identity reviews, and focused collaborations with teams that want
          practical findings.
        </p>
        <div class="contact-actions">
          {contactLinks.map((link) => (
            <a
              class="link-pill"
              href={link.href}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noopener noreferrer" : undefined}
            >
              <span>{link.label}</span><span class="arrow">↗</span>
            </a>
          ))}
        </div>
      </div>

      <footer class="foot">
        © 2026 Thanarak Kanyaprasit · Offensive security portfolio
      </footer>
    </div>
  </section>

  <script>
    const contactVideo = document.querySelector<HTMLVideoElement>("[data-contact-video]");
    const contactSection = document.getElementById("contact");

    if (contactVideo && contactSection) {
      const playContactVideo = () => {
        contactVideo.play().catch(() => {});
      };

      const pauseContactVideo = () => {
        contactVideo.pause();
      };

      new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            playContactVideo();
          } else {
            pauseContactVideo();
          }
        },
        {
          rootMargin: "65% 0px 65% 0px",
          threshold: 0,
        }
      ).observe(contactSection);
    }
  </script>
</Base>
